#!/usr/bin/env python3
# Simple CLI Battleship — single-player against hidden fleet
# Save as battleship.py and run: python3 battleship.py

import random
import string
import sys

SIZE = 6
SHIPS = [3, 3]  # lengths of ships to place
MAX_TURNS = 15

def make_board(size, fill='.'):
    return [[fill for _ in range(size)] for _ in range(size)]

def print_board(board, reveal=False, ships=None):
    header = '  ' + ' '.join(str(i+1) for i in range(len(board)))
    print(header)
    for r, row in enumerate(board):
        line = string.ascii_uppercase[r] + ' ' + ' '.join(row)
        if reveal and ships:
            # overlay ships on a copy for reveal
            pass
        print(line)

def place_ships(size, ships):
    grid = make_board(size, fill='.')
    placed = []
    for length in ships:
        placed_ok = False
        attempts = 0
        while not placed_ok and attempts < 200:
            attempts += 1
            dir = random.choice([(0,1),(1,0)])
            if dir == (0,1):  # horizontal
                r = random.randrange(0, size)
                c = random.randrange(0, size - length + 1)
                coords = [(r, c+i) for i in range(length)]
            else:  # vertical
                r = random.randrange(0, size - length + 1)
                c = random.randrange(0, size)
                coords = [(r+i, c) for i in range(length)]
            if any(grid[r2][c2] == 'S' for r2,c2 in coords):
                continue
            for r2,c2 in coords:
                grid[r2][c2] = 'S'
            placed.append(coords)
            placed_ok = True
        if not placed_ok:
            raise RuntimeError("Failed to place ships")
    return grid, placed

def parse_coord(s, size):
    s = s.strip().upper()
    if len(s) < 2:
        return None
    row_char = s[0]
    if row_char not in string.ascii_uppercase[:size]:
        return None
    try:
        col = int(s[1:]) - 1
    except ValueError:
        return None
    row = string.ascii_uppercase.index(row_char)
    if 0 <= row < size and 0 <= col < size:
        return (row, col)
    return None

def show_public(board):
    display = make_board(len(board), fill='.')
    for r in range(len(board)):
        for c in range(len(board)):
            v = board[r][c]
            if v == 'H':
                display[r][c] = 'X'
            elif v == 'M':
                display[r][c] = 'o'
            else:
                display[r][c] = '.'
    header = '  ' + ' '.join(str(i+1) for i in range(len(board)))
    print(header)
    for r, row in enumerate(display):
        print(string.ascii_uppercase[r] + ' ' + ' '.join(row))

def all_sunk(hidden_grid):
    for row in hidden_grid:
        for c in row:
            if c == 'S':
                return False
    return True

def main():
    size = SIZE
    hidden, ships = place_ships(size, SHIPS)
    public = make_board(size, fill='.')
    turns = 0
    print("Battleship — enter coordinates like A1, B3. Type 'quit' to exit.")
    while turns < MAX_TURNS:
        print(f"\nTurn {turns+1}/{MAX_TURNS}")
        show_public(public)
        s = input("Fire at: ").strip()
        if not s:
            continue
        if s.lower() in ('quit','exit'):
            print("Goodbye.")
            sys.exit(0)
        coord = parse_coord(s, size)
        if coord is None:
            print("Invalid coordinate.")
            continue
        r,c = coord
        if public[r][c] in ('H','M'):
            print("Already fired there.")
            continue
        turns += 1
        if hidden[r][c] == 'S':
            print("Hit!")
            public[r][c] = 'H'
            hidden[r][c] = 'H'
            # mark ship cells as hit; check sunk (optional)
            if all_sunk(hidden):
                print("\nYou sank all ships! Victory!")
                show_public(public)
                return
        else:
            print("Miss.")
            public[r][c] = 'M'
    print("\nOut of turns. You lose. Fleet was at:")
    # reveal hidden ships
    reveal = make_board(size, fill='.')
    for r in range(size):
        for c in range(size):
            if hidden[r][c] == 'S':
                reveal[r][c] = 'S'
            elif hidden[r][c] == 'H':
                reveal[r][c] = 'X'
            else:
                reveal[r][c] = '.'
    header = '  ' + ' '.join(str(i+1) for i in range(size))
    print(header)
    for r, row in enumerate(reveal):
        print(string.ascii_uppercase[r] + ' ' + ' '.join(row))

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\nInterrupted.")